{
  "tasks": {
    "start": "deno run --env-file --allow-net --allow-read --allow-run --allow-env server.ts",
    "dev": "deno run --env-file --allow-net --allow-read --allow-run --allow-env --watch server.ts",
    "build": "deno run -A build.ts"
  },
  "imports": {
    "@std/http/file-server": "jsr:@std/http@^1.1.2/file-server",
    "@google/genai": "npm:@google/genai@^2.10.0",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.43.0",
    "iconify-icon": "npm:iconify-icon@^1.0.8",
    "tailwindcss": "npm:tailwindcss@^4.0.0"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "deno.ns"]
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "lineWidth": 1000,
    "exclude": ["public/", "dist/"]
  },
  "lint": {
    "exclude": ["public/", "dist/"]
  }
}
